{
  "name": "@wyre-technology/node-clio",
  "version": "0.0.0-semantically-released",
  "description": "Node.js/TypeScript client library for the Clio Manage API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "publishConfig": { "registry": "https://npm.pkg.github.com" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/node-clio.git"
  },
  "license": "Apache-2.0",
  "keywords": ["clio", "legal", "api-client", "sdk", "typescript", "practice-management"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^1.0.0",
    "msw": "^2.0.0",
    "@types/node": "^20.0.0",
    "semantic-release": "^23.0.0",
    "@semantic-release/npm": "^11.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0"
  },
  "engines": { "node": ">=18.0.0" }
}
